<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KbsMobile.Features.Auth.Views.LoginPage"
             Title="Giriş">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="Kurum Girişi" FontSize="24" FontAttributes="Bold"/>
            <Entry Placeholder="Kullanıcı adı" Text="{Binding Username}"/>
            <Entry Placeholder="Şifre" IsPassword="True" Text="{Binding Password}"/>
            <HorizontalStackLayout>
                <CheckBox IsChecked="{Binding KeepSignedIn}"/>
                <Label Text="Beni hatırla" VerticalOptions="Center"/>
            </HorizontalStackLayout>
            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"/>
            <Button Text="Giriş Yap" Command="{Binding LoginCommand}"/>
            <Label Text="Demo: admin / 123456" FontSize="12"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
