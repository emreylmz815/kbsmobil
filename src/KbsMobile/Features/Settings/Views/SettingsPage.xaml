<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KbsMobile.Features.Settings.Views.SettingsPage"
             Title="Ayarlar">
    <VerticalStackLayout Padding="20" Spacing="12">
        <Label Text="Profil & Ayarlar" FontSize="20"/>
        <Label Text="Tema, API endpoint, offline ayarları bu ekranda genişletilebilir."/>
        <Button Text="Çıkış Yap" Command="{Binding LogoutCommand}" BackgroundColor="{StaticResource Error}"/>
    </VerticalStackLayout>
</ContentPage>
