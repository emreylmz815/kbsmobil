<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KbsMobile.Features.Dashboard.Views.DashboardPage"
             Title="Dashboard">
    <VerticalStackLayout Padding="20" Spacing="12">
        <Label Text="{Binding WelcomeMessage}" FontSize="18" FontAttributes="Bold"/>
        <Button Text="Haritaya Git" Command="{Binding OpenMapCommand}"/>
        <Button Text="Kayıtları Yönet" Command="{Binding OpenRecordsCommand}"/>
        <Button Text="Katman Paneli" Command="{Binding OpenLayersCommand}"/>
    </VerticalStackLayout>
</ContentPage>
